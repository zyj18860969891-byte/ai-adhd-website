    console.log('вҸ?[handleTaskDefer] Input notification type:', typeof notification);
    console.log('вҸ?[handleTaskDefer] Input notification keys:', Object.keys(notification || {}));
    console.log('вҸ?[handleTaskDefer] Input notification id:', notification?.id);
    console.log('вҸ?[handleTaskDefer] Input notification taskId:', notification?.taskId);
    console.log('вҸ?[handleTaskDefer] Input notification title:', notification?.title);
    
    // Handle string taskId (from button click)
    if (typeof notification === 'string') {
      console.log('вҸ?[handleTaskDefer] Handling string taskId:', notification);
