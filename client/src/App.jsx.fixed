                    console.log('рҹ”” Showing notification:', notifications[0].id);
                    console.log('рҹ”” Notification message:', notifications[0].message);
                    console.log('рҹ”” Notification details:', notifications[0]);
                    // еҰӮжһңжңүжңӘиҜ»йҖҡзҹҘпјҢжҳҫзӨәз¬¬дёҖдё?
                    setSnackbarMessage(notifications[0].message);
                    setCurrentNotification(notifications[0]);
                    setSnackbarOpen(true);
                    console.log('рҹ”” Snackbar opened with message:', notifications[0].message);
                  } else {
                    console.log('рҹ”” No notifications to show');
                    setSnackbarMessage('жҡӮж— ж–°йҖҡзҹҘ');
                    setSnackbarSeverity('info');
                    setSnackbarOpen(true);
                  }
                }}
                style={{ cursor: 'pointer' }}
                title="зӮ№еҮ»жҹҘзңӢжҸҗйҶ’"
              />
            </Badge>
          </Toolbar>
