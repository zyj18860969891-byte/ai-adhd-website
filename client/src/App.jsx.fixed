          console.log('рҹ“Ҙ Old notifications:', notifications);
          console.log('рҹ“Ҙ New notifications:', pendingNotifications);
        }
        
        // Show modal for new reminders
        if (newNotifications.length > 0) {
          console.log('рҹ”” Found', newNotifications.length, 'new notifications');
          console.log('рҹ”” New notifications details:', newNotifications);
          // дҪҝз”Ё requestAnimationFrame дјҳеҢ–жҖ§иғҪ
          if (isMounted) {
            requestAnimationFrame(() => {
              newNotifications.forEach(notification => {
                console.log('рҹ”” Processing notification:', notification.id, 'type:', notification.type);
                if (notification.type === 'reminder') {
                  console.log('рҹ”” New reminder detected:', notification.message);
                  console.log('рҹ”” Setting snackbar message:', notification.message);
                  setSnackbarMessage(notification.message)
                  console.log('рҹ”” Setting current notification:', notification.id);
                  setCurrentNotification(notification)
                  console.log('рҹ”” Opening snackbar modal');
                  setSnackbarOpen(true)
                  console.log('рҹ”” Modal opened for new reminder');
                } else {
                  console.log('рҹ”” Notification is not a reminder, skipping');
                }
              })
            });
          }
        } else {
          console.log('рҹ”” No new notifications found');
          console.log('рҹ”” Pending notifications:', pendingNotifications);
          console.log('рҹ”” Current notifications:', notifications);
          console.log('рҹ”” Notifications comparison:', JSON.stringify(pendingNotifications) === JSON.stringify(notifications));
        }
        
        // Show browser notification for new reminders
        newNotifications.forEach(notification => {
          if (notification.type === 'reminder' && 
              'Notification' in window && 
              Notification.permission === 'granted') {
            console.log('рҹҢҗ Showing browser notification:', notification.title);
            new Notification(notification.title, {
              body: notification.message,
              icon: '/icons/icon-72x72.png'
            })
          } else if (notification.type === 'reminder') {
            console.log('рҹҢҗ Browser notification not shown - permission:', 
              'Notification' in window ? Notification.permission : 'Not supported');
          }
        })
        
        // Debug the current state
        debugNotificationState();
      } catch (error) {
        if (isMounted) {
          console.error('Failed to load notifications:', error)
          console.error('Error details:', error.response || error.message || error);
        }
      }
    }

    // Request notification permission
    if ('Notification' in window && Notification.permission === 'default') {
      console.log('рҹҢҗ Requesting notification permission...');
      Notification.requestPermission()
    }

    loadNotifications()
    // дјҳеҢ–иҪ®иҜўйў‘зҺҮпјҢйҒҝе…ҚжҖ§иғҪй—®йўҳ
    const interval = setInterval(async () => {
      if (isMounted) {
        await loadNotifications();
      }
    }, 5000) // еҮҸе°‘еҲ?з§’дёҖж¬?
    
    return () => {
      isMounted = false;
      clearInterval(interval);
    }
  }, [])

  // Auto-show modal when notifications change (for cross-page reminders)
  useEffect(() => {
    // йҳІжӯўйҮҚеӨҚи§ҰеҸ‘е’ҢжҖ§иғҪй—®йўҳ
    if (!notifications || notifications.length === 0 || snackbarOpen) {
      return;
    }
    
    console.log('рҹ”„ Notifications changed:', notifications.length);
    console.log('рҹ”„ Snackbar open status:', snackbarOpen);
    
    // еҸӘеӨ„зҗҶжңҖж–°зҡ„йҖҡзҹҘ
    const latestNotification = notifications[notifications.length - 1];
    console.log('рҹ”„ Latest notification:', latestNotification?.id);
    
    if (latestNotification && latestNotification.type === 'reminder') {
      console.log('рҹ”„ Auto-showing reminder modal for:', latestNotification.message);
      console.log('рҹ”„ Setting snackbar message:', latestNotification.message);
      
      // дҪҝз”Ё requestAnimationFrame дјҳеҢ–жҖ§иғҪ
      requestAnimationFrame(() => {
        setSnackbarMessage(latestNotification.message);
        setCurrentNotification(latestNotification);
        setSnackbarOpen(true);
        console.log('рҹ”„ Modal opened successfully');
      });
    } else {
      console.log('рҹ”„ Latest notification is not a reminder or is null');
      if (latestNotification) {
        console.log('рҹ”„ Notification type is:', latestNotification.type);
      }
    }
  }, [notifications, snackbarOpen])

  // Debug function to check notification state
  const debugNotificationState = () => {
    console.log('=== DEBUG NOTIFICATION STATE ===');
    console.log('Current notifications:', notifications);
    console.log('Snackbar open:', snackbarOpen);
    console.log('Current notification:', currentNotification);
    console.log('Pending notifications count:', notifications.filter(n => n.status === 'pending').length);
    console.log('Reminder notifications count:', notifications.filter(n => n.type === 'reminder').length);
    console.log('=== END DEBUG ===');
  }

  // Test function to create a test notification has been removed as the test page is no longer needed

  // Manual refresh function
  const refreshNotifications = async () => {
    try {
      console.log('рҹ”„ Manually refreshing notifications...');
      const userNotifications = await notificationService.getUserNotifications('user-1');
      console.log('рҹ”„ Manual refresh result:', userNotifications);
      
      const pendingNotifications = userNotifications.filter(n => n.status === 'pending');
      setNotifications(pendingNotifications);
      
      setSnackbarMessage('Notifications refreshed manually');
      setSnackbarSeverity('info');
      setSnackbarOpen(true);
    } catch (error) {
      console.error('рҹ”„ Failed to refresh notifications:', error);
      setSnackbarMessage('Failed to refresh notifications');
      setSnackbarSeverity('error');
      setSnackbarOpen(true);
    }
  }

  // Load task progress
  useEffect(() => {
    const loadTaskProgress = async () => {
      try {
        const progress = await taskService.getTaskProgress()
        setTaskProgress(progress)
      } catch (error) {
        console.error('Failed to load task progress:', error)
      }
    }

    loadTaskProgress()
    const interval = setInterval(loadTaskProgress, 30000) // Refresh every 30 seconds
    return () => clearInterval(interval)
  }, [])

  const menuItems = [
    { text: 'йҰ–йЎө', icon: <HomeIcon />, path: '/' },
    { text: 'д»»еҠЎзңӢжқҝ', icon: <ListIcon />, path: '/tasks' },
    { text: 'ж·»еҠ д»»еҠЎ', icon: <AddIcon />, path: '/add' },
    { text: 'ж•°жҚ®еҲҶжһҗ', icon: <ChartIcon />, path: '/analytics' },
    { text: 'и®ҫзҪ®', icon: <SettingsIcon />, path: '/settings' }
