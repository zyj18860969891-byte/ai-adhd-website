        console.log('рҹ“Ҙ Server response length:', Array.isArray(userNotifications) ? userNotifications.length : 'Not an array');
        
        // Check if response is valid
        if (!userNotifications || !Array.isArray(userNotifications)) {
          console.log('рҹ“Ҙ Invalid notifications response, using empty array');
          if (isMounted) setNotifications([]);
          return;
        }
        
        const pendingNotifications = userNotifications.filter(n => n.status === 'pending')
        console.log('рҹ“Ҙ Pending notifications count:', pendingNotifications.length);
        console.log('рҹ“Ҙ Pending notifications:', pendingNotifications);
        
