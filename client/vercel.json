{
  "version": 2,
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "https://ai-adhd-website-production.up.railway.app/api/$1"
    },
    {
      "src": "/api/services/(.*)",
      "dest": "https://ai-adhd-website-production.up.railway.app/api/services/$1"
    },
    {
      "src": "/(.*\\.(js|css|png|jpg|jpeg|gif|ico|svg|woff|woff2|ttf|eot|json))$",
      "dest": "/$1"
    },
    {
      "src": "/(.*)",
      "dest": "/index.html"
    }
  ],
  "env": {
    "VITE_API_BASE_URL": "https://ai-adhd-website-production.up.railway.app",
    "VITE_WS_URL": "wss://ai-adhd-website-production.up.railway.app"
  },
  "build": {
    "env": {
      "GENERATE_SOURCEMAP": "false"
    }
  }
}